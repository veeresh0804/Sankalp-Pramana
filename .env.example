# ─────────────────────────────────────────────────────────────
# AI 3D Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── Dataset Sources ──────────────────────────────────────────
# Comma-separated priority order. Available: objaverse, sketchfab, polyhaven, mock
# Default: sketchfab,polyhaven,mock   (objaverse = slow 200MB first-run download)
RETRIEVAL_SOURCES=sketchfab,polyhaven,mock

# ── Sketchfab API ────────────────────────────────────────────
# Get free token: https://sketchfab.com → Settings → Password & API
SKETCHFAB_API_TOKEN=your_sketchfab_token_here

# ── Google Cloud Storage ─────────────────────────────────────
GCS_BUCKET_NAME=ai-3d-models-bucket
GCS_PROJECT_ID=your-gcp-project-id

# ── RAG / LLM (optional) ─────────────────────────────────────
# Leave blank to use Wikipedia + curated KB instead
OPENAI_API_KEY=
USE_LLM_RAG=false

# ── Tuning ───────────────────────────────────────────────────
TOP_K_CANDIDATES=10
MIN_CONFIDENCE=0.3
CLIP_THRESHOLD=0.25
CACHE_TTL=3600
